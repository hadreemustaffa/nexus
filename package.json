{
  "name": "nexus",
  "private": true,
  "version": "0.0.0",
  "description": "AI Knowledge Engine",
  "author": "Hadree Mustaffa",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:client": "eslint client",
    "lint:server": "eslint server",
    "lint:fix": "eslint . --fix",
    "lint:fix:client": "eslint client --fix",
    "lint:fix:server": "eslint server --fix",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "build:shared": "npm run build -w @nexus/shared",
    "build:server": "npm run build -w server",
    "build:client": "npm run build -w client",
    "start": "npm run build && concurrently \"npm run start:client\" \"npm run start:server\"",
    "start:server": "npm run start -w server",
    "start:client": "npm run preview -w client"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
