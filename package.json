{
  "name": "nexus",
  "private": true,
  "version": "0.0.0",
  "description": "AI Knowledge Engine",
  "author": "Hadree Mustaffa",
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build:shared && npm run build:server && npm run build:client",
    "build:shared": "npm run build -w @nexus/shared",
    "build:server": "npm run build -w server",
    "build:client": "npm run build -w client",
    "start": "npm run build && concurrently \"npm run start:client\" \"npm run start:server\"",
    "start:server": "npm run start -w server",
    "start:client": "npm run preview -w client",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc -p tsconfig.json --pretty --noEmit'"
    ]
  }
}
